{"type":"item.started","item":{"id":"item_73","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport json, shutil\nfrom pathlib import Path\nfrom datasets import load_dataset\nbase = Path('datasets')\n(base / 'samples').mkdir(parents=True, exist_ok=True)\nfor name in ['ag_news']:\n    ds = load_dataset(name)\n    out = base / name\n    ds.save_to_disk(str(out))\n    sample = {split: ds[split][:3] for split in ds.keys()}\n    with open(base / 'samples' / f'{name}_sample.json', 'w') as f:\n        json.dump(sample, f, indent=2)\n    print(name, {k: len(v) for k, v in ds.items()})\nbench_src = Path('code/Linguistic-Steganalysis-with-LLMs/data')\nbench_dst = base / 'llm_steganalysis_benchmark'\nif bench_dst.exists():\n    shutil.rmtree(bench_dst)\nshutil.copytree(bench_src, bench_dst)\nfor p in sorted(bench_dst.rglob('*.txt')):\n    print('benchmark', p.relative_to(base), p.stat().st_size)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

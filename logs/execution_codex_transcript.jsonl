{"type":"item.started","item":{"id":"item_102","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport pandas as pd\nouts = pd.read_json('results/raw/model_outputs.jsonl', lines=True)\n# detection synthetic only\nsyn_det = outs[outs.task=='detection'].copy()\nprint('OVERALL DETECTION BY MODEL AND SCHEME')\nfor model in syn_det.model.unique():\n    sub=syn_det[syn_det.model==model]\n    grp=sub.groupby('scheme').apply(lambda g: pd.Series({\n        'accuracy': (g.label==g.pred_contains_hidden_message).mean(),\n        'precision': ((g.pred_contains_hidden_message & (g.label==1)).sum() / max(g.pred_contains_hidden_message.sum(),1)),\n        'recall': ((g.pred_contains_hidden_message & (g.label==1)).sum() / (g.label==1).sum()),\n        'n': len(g)\n    }))\n    print('\\\\n', model)\n    print(grp.round(3).to_string())\n\next = outs[outs.task=='extraction'].copy()\next['exact'] = (ext.pred_message==ext.secret).astype(int)\next['char_acc'] = [sum(a==b for a,b in zip((p+'______')[:6],t))/6 for p,t in zip(ext.pred_message.astype(str), ext.secret.astype(str))]\nprint('\\\\nOVERALL EXTRACTION BY MODEL AND SCHEME')\nfor model in ext.model.unique():\n    sub=ext[ext.model==model]\n    grp=sub.groupby('scheme').agg(exact_recovery=('exact','mean'), char_accuracy=('char_acc','mean'), n=('exact','size'))\n    print('\\\\n', model)\n    print(grp.round(3).to_string())\n\nprint('\\\\nREPRESENTATIVE FAILURES')\nfor model in ['gpt-4.1','gpt-5']:\n    print('\\\\nMODEL', model)\n    sample=ext[(ext.model==model) & (ext.exact==0)][['scheme','corpus','secret','pred_message']].head(6)\n    print(sample.to_string(index=False))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
